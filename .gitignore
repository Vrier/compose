# --- Dependencies ---
node_modules/

# Note: dist/ is the self-contained release artifact (generated by `npm run build`).
# It is kept in the repo so the builds are downloadable without a toolchain.
# To treat it as purely generated, uncomment the next line:
# dist/

# --- Copyrighted source material — kept on disk for reference, never shipped/committed ---
# Heim & Kratzer book scan + OCR, Coppock & Champollion PDFs, excerpt PDFs, etc.
uploads/

# --- Server build artifacts (generated by `npm run build:server`) ---
server/template.html
server/pb_public/*
!server/pb_public/.gitkeep

# --- PocketBase (binary fetched by server/get-pocketbase.sh; data is local state) ---
server/pocketbase
server/pb_data/

# --- Misc ---
.thumbnail
.DS_Store
Thumbs.db
*.log
