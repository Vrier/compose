# ===========================================================================
# COMPOSE — Caddyfile (S7/W8)
# Installed at /etc/caddy/Caddyfile. Caddy obtains and renews Let's Encrypt
# certificates automatically for every site listed here.
# ===========================================================================

# Personal site — static clone of github.com/Vrier/vrier.github.io at
# /srv/www (owned by `compose`; that repo's own Actions workflow
# fast-forwards it on every push). Apex redirects to www.
tstephen.com {
	redir https://www.tstephen.com{uri} permanent
}

www.tstephen.com {
	root * /srv/www
	file_server
	encode gzip
}

# COMPOSE — reverse proxy to PocketBase (systemd unit `compose`)
compose.tstephen.com {
	reverse_proxy 127.0.0.1:8090
	encode gzip
}
