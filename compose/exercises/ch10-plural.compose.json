  "exercises": [
    {
      "title": "A. Plural predicate (‚àóP)",
      "instructions": "The plural noun \"hobbits\" denotes ‚àóhobbit of type ‚ü®e,t‚ü©. It is true of any individual that is either a hobbit or a sum of hobbits. Build the NP and check its type ‚Äî it should be ‚ü®e,t‚ü©, same as the singular \"hobbit\".",
      "items": [
        {
          "sentence": "hobbits (‚àóhobbit)",
          "tree": "[.NP [.N hobbit ] [.Pl -s ] ]",
          "targets": [
            "‚àóhobbit"
          ]
        },
        {
